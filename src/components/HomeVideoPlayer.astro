---
import { homeVideo } from '../data/site';
---

<article
	class="group relative min-w-0 overflow-hidden rounded-[var(--radius-card)] border border-violet-500/20 bg-gradient-to-b from-[rgba(34,28,48,0.95)] to-[rgba(18,16,26,0.98)] shadow-[0_10px_28px_rgba(0,0,0,0.28)]"
	data-home-video
>
	<button
		type="button"
		class="relative grid min-h-[clamp(220px,56vw,520px)] w-full place-items-center overflow-hidden bg-[#0a0612] p-0 transition-opacity hover:opacity-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-[var(--color-orchid)] data-[hidden=true]:hidden"
		data-video-trigger
		aria-label={`Play ${homeVideo.title}`}
	>
		<img
			src={homeVideo.thumbnail}
			alt={homeVideo.thumbnailAlt}
			width="1280"
			height="720"
			class="absolute inset-0 h-full w-full scale-[1.02] object-cover transition-transform duration-500 group-hover:scale-105"
			loading="lazy"
			decoding="async"
		/>
		<span
			class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,6,18,0.15)_0%,rgba(10,6,18,0.55)_100%),radial-gradient(circle_at_center,rgba(124,58,237,0.18),transparent_65%)]"
			aria-hidden="true"
		></span>
		<span
			class="relative z-10 inline-flex h-[3.75rem] w-[3.75rem] items-center justify-center rounded-full border border-white/30 bg-gradient-to-br from-violet-600 to-fuchsia-500 text-white shadow-[0_12px_32px_rgba(0,0,0,0.35),0_0_28px_rgba(168,85,247,0.45)] transition-transform duration-300 group-hover:scale-105 sm:h-[4.5rem] sm:w-[4.5rem]"
			aria-hidden="true"
		>
			<svg class="ml-0.5 h-7 w-7 sm:h-8 sm:w-8" viewBox="0 0 24 24" fill="currentColor">
				<path d="M8 5.14v13.72L19 12 8 5.14z"></path>
			</svg>
		</span>
		<span
			class="absolute bottom-4 left-4 z-10 rounded-full border border-violet-300/25 bg-[rgba(10,6,18,0.72)] px-2.5 py-1 text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[#d8c9ef] backdrop-blur-sm"
		>
			Watch demo
		</span>
	</button>

	<video
		class="hidden min-h-[clamp(220px,56vw,520px)] w-full bg-black object-contain data-[active=true]:block"
		data-video-player
		controls
		playsinline
		preload="none"
		aria-label={homeVideo.title}
	></video>
</article>

<script define:vars={{ videoSrc: homeVideo.src }}>
	document.querySelectorAll('[data-home-video]').forEach((root) => {
		const trigger = root.querySelector('[data-video-trigger]');
		const player = root.querySelector('[data-video-player]');

		trigger?.addEventListener('click', () => {
			if (!(player instanceof HTMLVideoElement)) return;

			player.src = videoSrc;
			player.dataset.active = 'true';
			trigger.dataset.hidden = 'true';
			root.classList.add('is-playing');

			const playPromise = player.play();
			if (playPromise) {
				playPromise.catch(() => {
					player.controls = true;
				});
			}
		});
	});
</script>
