---
import PageLayout from '../../layouts/PageLayout.astro';
import { productInfo, siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'Theisle Aimbot - Settings & Controls';
const description = siteConfig.metaDescription;
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/theisle-aimbot/"
	heading="The Isle Aimbot"
	intro="The Isle Aimbot is the aim-assist feature set inside The Isle Cheats. This page explains the controls players usually evaluate before choosing a package."
	heroImage={theIsleImages.product[0].src}
	heroAlt="The Isle Aimbot combat preview"
	gallery={[theIsleImages.product[0], theIsleImages.product[1], theIsleImages.product[4]]}
	ctaPrimary={{ href: '/pricing/', label: 'Choose a Package' }}
	ctaSecondary={{ href: '/theisle-esp/', label: 'Explore ESP' }}
>
	<section class="card-panel">
		<h2>What The Isle Aimbot includes</h2>
		<ul>
			{productInfo.features.aimbot.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2>Who this page is for</h2>
		<p>
			Use this page if you are comparing aim assist behavior, configuration options, and whether Aimbot
			belongs in your The Isle Cheats package. For visibility tools, see
			<a href="/theisle-esp/">The Isle ESP</a>.
		</p>
	</section>

	<section class="card-panel">
		<h2>Next steps</h2>
		<ul>
			<li><a href="/features/">Review the complete feature list</a></li>
			<li><a href="/pricing/">Compare Aimbot-ready packages and pricing</a></li>
			<li><a href="/updates/">Check recent product updates</a></li>
			<li><a href="/support/">Contact support with setup questions</a></li>
		</ul>
	</section>
</PageLayout>
