---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import HomeVideoPlayer from '../components/HomeVideoPlayer.astro';
import ProductCard from '../components/ProductCard.astro';
import Gallery from '../components/Gallery.astro';
import HomeSeo from '../components/HomeSeo.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { homeFaqs, homeSeo, productInfo, siteConfig } from '../data/site';

const title = homeSeo.title;
const description = homeSeo.description;

const productSchema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: productInfo.name,
	applicationCategory: 'GameApplication',
	operatingSystem: 'Windows',
	description: productInfo.summary,
	offers: productInfo.plans.map((plan) => ({
		'@type': 'Offer',
		name: `${productInfo.name} ${plan.label}`,
		price: plan.price.toFixed(2),
		priceCurrency: productInfo.currency,
		availability: 'https://schema.org/InStock',
		url: `${siteConfig.url}/pricing/`,
	})),
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: homeFaqs.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer,
		},
	})),
};
---

<Layout title={title} description={description} canonicalPath="/" ogImage="/images/hero.webp">
	<script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<Navbar />
	<main class="site">
		<Hero />
		<section class="site__section" id="features" data-nav-section="features" aria-label="Product packages">
			<div class="shell">
				<div class="features-split">
					<HomeVideoPlayer />
					<ProductCard />
				</div>
			</div>
		</section>
		<section class="site__section site__section--seo" id="why-us" data-nav-section="why-us">
			<HomeSeo />
		</section>
		<section class="site__section site__section--gallery" id="demo" data-nav-section="demo">
			<div class="shell">
				<Gallery />
			</div>
		</section>
		<SiteFooter />
	</main>
</Layout>

<style>
	.site {
		overflow-x: clip;
	}

	.site__section {
		padding-block: var(--section-space);
	}

	.site__section--seo {
		padding-top: 0.25rem;
	}

	.site__section--gallery {
		padding-top: 0.5rem;
		padding-bottom: 2rem;
	}

	.features-split {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: clamp(1.25rem, 2.5vw, 2rem);
		align-items: stretch;
	}

	@media (max-width: 900px) {
		.features-split {
			grid-template-columns: 1fr;
		}
	}
</style>
