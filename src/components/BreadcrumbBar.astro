---
import { productInfo, siteConfig } from '../data/site';

interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	items?: Crumb[];
}

const {
	items = [
		{ label: 'Main page', href: '/' },
		{ label: 'Plans', href: '/pricing/' },
		{ label: siteConfig.name },
	],
} = Astro.props;
---

<nav class="crumb-bar" aria-label="Breadcrumb">
	<div class="crumb-bar__inner">
		<ol class="crumb-bar__list">
			{
				items.map((item, index) => (
					<li class="crumb-bar__item">
						{index > 0 && (
							<span class="crumb-bar__sep" aria-hidden="true">
								/
							</span>
						)}
						{item.href ? (
							<a href={item.href} class="crumb-bar__link">
								{item.label}
							</a>
						) : (
							<span class="crumb-bar__current" aria-current="page">
								{item.label}
							</span>
						)}
					</li>
				))
			}
		</ol>

		<a href="/updates/" class="activity-btn">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path
					d="M4 6h16M4 12h10M4 18h14"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"></path>
			</svg>
			Updates
		</a>
	</div>
</nav>

<style>
	.crumb-bar {
		border-block: 1px solid rgba(168, 85, 247, 0.12);
		background: rgba(14, 10, 22, 0.85);
		backdrop-filter: blur(12px);
	}

	.crumb-bar__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(100% - (var(--page-gutter) * 2), var(--page-max));
		margin: 0 auto;
		padding: 0.85rem 0;
	}

	.crumb-bar__list {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.875rem;
		color: var(--color-faint);
	}

	.crumb-bar__item {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.crumb-bar__sep {
		opacity: 0.45;
	}

	.crumb-bar__link {
		color: var(--color-muted);
		transition: color 0.2s ease;
	}

	.crumb-bar__link:hover {
		color: var(--color-orchid);
	}

	.crumb-bar__current {
		color: var(--color-ink);
		font-weight: 500;
	}

	.activity-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
		padding: 0.55rem 1rem;
		border-radius: 0.65rem;
		border: 1px solid rgba(192, 132, 252, 0.22);
		background: rgba(34, 28, 48, 0.8);
		color: var(--color-ink);
		font-size: 0.875rem;
		font-weight: 600;
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			box-shadow 0.2s ease;
	}

	.activity-btn:hover {
		border-color: rgba(192, 132, 252, 0.45);
		background: rgba(48, 36, 72, 0.9);
	}

	@media (max-width: 640px) {
		.crumb-bar__inner {
			flex-direction: column;
			align-items: stretch;
		}

		.activity-btn {
			justify-content: center;
			min-height: 2.75rem;
		}

		.crumb-bar__list {
			row-gap: 0.45rem;
		}
	}
</style>
