---
import SeoImage from './SeoImage.astro';
import { theIsleImages } from '../data/theisle';
import { homeSeo, siteConfig } from '../data/site';

interface Props {
	subtitle?: string;
}

const {
	subtitle = homeSeo.subtitle,
} = Astro.props;
---

<section class="hero" id="home" aria-label="Hero">
	<div class="hero__media">
		<SeoImage
			src={theIsleImages.hero}
			width={1400}
			height={788}
			class="hero__bg"
			fetchpriority="high"
			bare
		/>
		<div class="hero__veil" aria-hidden="true"></div>
	</div>

	<div class="hero__inner">
		<div class="hero__copy">
			<h1 class="hero__title">{homeSeo.heroLine1}</h1>
			<p class="hero__tagline">{homeSeo.heroLine2}</p>
			<p class="hero__subtitle">{subtitle}</p>
			<div class="hero__cta">
				<a
					href={siteConfig.checkoutUrl}
					class="hero__btn hero__btn--primary"
					target="_blank"
					rel="noopener noreferrer"
				>
					Compare packages
				</a>
				<a
					href={siteConfig.checkoutUrl}
					class="hero__btn hero__btn--ghost"
					target="_blank"
					rel="noopener noreferrer"
				>
					Get Access
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		isolation: isolate;
		min-height: clamp(340px, 46vw, 460px);
	}

	.hero__media {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 70% 40%;
	}

	.hero__veil {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(90deg, #0a0612 0%, rgba(10, 6, 18, 0.9) 36%, rgba(10, 6, 18, 0.4) 68%, rgba(10, 6, 18, 0.6) 100%),
			linear-gradient(180deg, rgba(10, 6, 18, 0.3) 0%, transparent 42%, rgba(10, 6, 18, 0.8) 100%);
		pointer-events: none;
	}

	.hero__inner {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		width: min(100% - (var(--page-gutter) * 2), var(--page-max));
		margin: 0 auto;
		padding: 3.5rem 0 3rem;
		min-height: inherit;
	}

	.hero__copy {
		max-width: min(36rem, 100%);
		min-width: 0;
	}

	.hero__title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		line-height: 1.08;
		letter-spacing: -0.03em;
		text-wrap: balance;
	}

	.hero__tagline {
		margin: 0.65rem 0 0;
		font-family: var(--font-display);
		font-size: clamp(1.1rem, 2.4vw, 1.45rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-orchid);
	}

	.hero__subtitle {
		margin: 0.85rem 0 0;
		max-width: 24rem;
		font-size: clamp(0.92rem, 1.4vw, 1rem);
		line-height: 1.6;
		color: var(--color-muted);
	}

	.hero__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.4rem;
	}

	.hero__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1.15rem;
		border-radius: 0.7rem;
		font-size: 0.92rem;
		font-weight: 600;
		text-align: center;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease;
	}

	.hero__btn--primary {
		border: 1px solid rgba(168, 85, 247, 0.45);
		background: rgba(124, 58, 237, 0.88);
		color: white;
	}

	.hero__btn--primary:hover {
		background: rgba(124, 58, 237, 1);
		border-color: rgba(192, 132, 252, 0.55);
	}

	.hero__btn--ghost {
		border: 1px solid rgba(168, 85, 247, 0.22);
		background: rgba(18, 16, 26, 0.72);
		color: var(--color-ink);
	}

	.hero__btn--ghost:hover {
		border-color: rgba(168, 85, 247, 0.4);
		background: rgba(34, 28, 48, 0.9);
	}

	@media (max-width: 760px) {
		.hero {
			min-height: min(64svh, 500px);
		}

		.hero__bg {
			object-position: center 30%;
		}

		.hero__veil {
			background:
				linear-gradient(180deg, rgba(10, 6, 18, 0.55) 0%, rgba(10, 6, 18, 0.35) 40%, rgba(10, 6, 18, 0.92) 100%),
				linear-gradient(90deg, rgba(10, 6, 18, 0.55), transparent 75%);
		}

		.hero__inner {
			align-items: flex-end;
			padding-top: 4.75rem;
			padding-bottom: 1.5rem;
		}

		.hero__copy {
			max-width: none;
			width: 100%;
		}

		.hero__title {
			font-size: clamp(1.75rem, 8vw, 2.35rem);
		}

		.hero__tagline {
			font-size: 1.05rem;
		}

		.hero__subtitle {
			max-width: none;
		}

		.hero__cta {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
		}

		.hero__btn {
			width: 100%;
			min-height: 2.75rem;
		}
	}
</style>
