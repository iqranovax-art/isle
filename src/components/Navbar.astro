---
import { theIsleImages } from '../data/theisle';
import { mainNav, siteConfig } from '../data/site';

const currentPath = Astro.url.pathname;
const currentHash = Astro.url.hash.replace('#', '');
---

<header class="nav" data-nav>
	<div class="nav__bar">
		<a href="/#home" class="nav__brand" aria-label={`${siteConfig.name} home page`}>
			<img
				src={theIsleImages.logo}
				alt={siteConfig.name}
				width="44"
				height="44"
				class="nav__logo"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
			<span class="nav__name">{siteConfig.name}</span>
		</a>

		<nav class="nav__center" id="nav-panel" data-nav-panel aria-label="Primary">
			<ul class="nav__list" role="list">
				{
					mainNav.map((link) => (
						<li>
							<a
								href={link.href}
								class="nav__link"
								data-nav-link
								data-section={link.section}
								aria-current={currentPath === '/' && currentHash === link.section ? 'page' : undefined}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="nav__actions">
			<a href={siteConfig.checkoutUrl} class="nav__buy">buy</a>
		</div>

		<button
			type="button"
			class="nav__toggle"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="nav-panel"
			data-nav-toggle
		>
			<span class="nav__toggle-icon" aria-hidden="true"></span>
		</button>
	</div>
</header>

<script>
	const nav = document.querySelector('[data-nav]');
	if (nav) {
		const toggle = nav.querySelector('[data-nav-toggle]');
		const panel = nav.querySelector('[data-nav-panel]');
		const links = Array.from(nav.querySelectorAll('[data-nav-link]'));
		const sections = Array.from(document.querySelectorAll('[data-nav-section]'));
		const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
		let activeSection = window.location.hash.replace('#', '') || 'home';
		let clickedSection: string | null = null;

		const setOpen = (open: boolean) => {
			toggle?.setAttribute('aria-expanded', String(open));
			toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
			nav.classList.toggle('is-open', open);
			document.body.classList.toggle('nav-open', open);
		};

		const setActive = (sectionId: string) => {
			activeSection = sectionId;
			links.forEach((link) => {
				const isActive = link.getAttribute('data-section') === sectionId;
				link.classList.toggle('is-active', isActive);
				link.setAttribute('aria-current', isActive ? 'page' : 'false');
			});
		};

		const scrollToSection = (sectionId: string) => {
			const target = document.getElementById(sectionId);
			if (target) {
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
				history.replaceState(null, '', `#${sectionId}`);
			}
		};

		links.forEach((link) => {
			link.addEventListener('click', (event) => {
				const href = link.getAttribute('href') || '';
				const sectionId = link.getAttribute('data-section') || '';
				const onHome = window.location.pathname === '/' || window.location.pathname === '/index.html';

				if (href.startsWith('/#') && onHome) {
					event.preventDefault();
					clickedSection = sectionId;
					setActive(sectionId);
					scrollToSection(sectionId);
					setOpen(false);
					window.setTimeout(() => {
						clickedSection = null;
					}, 1200);
					return;
				}

				setOpen(false);
			});
		});

		toggle?.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		panel?.querySelectorAll('a').forEach((link) => {
			if (!link.hasAttribute('data-nav-link')) {
				link.addEventListener('click', () => setOpen(false));
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && nav.classList.contains('is-open')) {
				setOpen(false);
			}
		});

		const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8);
		onScroll();
		window.addEventListener('scroll', onScroll, { passive: true });

		if (isHome && sections.length > 0) {
			const navOffset = () => {
				const bar = nav.querySelector('.nav__bar');
				return (bar?.getBoundingClientRect().height ?? 72) + 24;
			};

			const updateActiveFromScroll = () => {
				if (clickedSection) return;

				const scrollPos = window.scrollY + navOffset();
				let current = sections[0]?.id || 'home';

				sections.forEach((section) => {
					if (section instanceof HTMLElement && section.offsetTop <= scrollPos + 2) {
						current = section.id;
					}
				});

				setActive(current);
			};

			let scrollRaf = 0;
			const onSectionScroll = () => {
				if (scrollRaf) return;
				scrollRaf = window.requestAnimationFrame(() => {
					scrollRaf = 0;
					updateActiveFromScroll();
				});
			};

			window.addEventListener('scroll', onSectionScroll, { passive: true });
			window.addEventListener('resize', onSectionScroll, { passive: true });

			if (window.location.hash) {
				const hash = window.location.hash.replace('#', '');
				if (document.getElementById(hash)) {
					setActive(hash);
				}
			} else {
				setActive('home');
			}

			updateActiveFromScroll();
		} else if (window.location.hash) {
			setActive(window.location.hash.replace('#', ''));
		} else {
			setActive('home');
		}
	}
</script>

<style is:global>
	body.nav-open {
		overflow: hidden;
	}
</style>

<style>
	.nav {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.7rem var(--page-gutter) 0;
		padding-top: calc(0.7rem + env(safe-area-inset-top, 0px));
		pointer-events: none;
	}

	.nav__bar {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		width: min(100%, var(--page-max));
		margin: 0 auto;
		padding: 0.6rem 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(129, 140, 248, 0.18);
		background: rgba(10, 8, 20, 0.68);
		backdrop-filter: blur(18px) saturate(1.35);
		-webkit-backdrop-filter: blur(18px) saturate(1.35);
		box-shadow:
			0 8px 32px rgba(0, 0, 0, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.04);
		pointer-events: auto;
		transition:
			background 0.3s ease,
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}

	.nav.is-scrolled .nav__bar {
		background: rgba(8, 6, 16, 0.92);
		border-color: rgba(147, 51, 234, 0.28);
		box-shadow:
			0 12px 36px rgba(0, 0, 0, 0.38),
			0 0 0 1px rgba(99, 102, 241, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	.nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		flex-shrink: 0;
		justify-self: start;
		color: var(--color-ink);
		transition: opacity 0.3s ease;
	}

	.nav__brand:hover {
		opacity: 0.92;
	}

	.nav__logo {
		display: block;
		width: 2.75rem;
		height: 2.75rem;
		object-fit: contain;
		border-radius: 0.65rem;
		background: rgba(168, 85, 247, 0.14);
		border: 1px solid rgba(192, 132, 252, 0.28);
		box-shadow: 0 0 18px rgba(124, 58, 237, 0.22);
		padding: 0.2rem;
	}

	.nav__name {
		font-family: var(--font-display);
		font-size: 0.94rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.nav__center {
		display: flex;
		justify-content: center;
		justify-self: center;
		min-width: 0;
	}

	.nav__list {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: nowrap;
		gap: 0.2rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.nav__link {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 0.8rem;
		border-radius: 0.65rem;
		color: var(--color-muted);
		font-size: 0.84rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		white-space: nowrap;
		transition:
			color 0.3s ease,
			background 0.3s ease,
			box-shadow 0.3s ease,
			text-shadow 0.3s ease;
	}

	.nav__link::after {
		content: '';
		position: absolute;
		left: 0.75rem;
		right: 0.75rem;
		bottom: 0.28rem;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 50%, #c084fc 100%);
		box-shadow: 0 0 10px rgba(139, 92, 246, 0.65);
		transform: scaleX(0);
		transform-origin: center;
		opacity: 0;
		transition:
			transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.3s ease;
	}

	.nav__link:hover {
		color: #ede9fe;
		background: rgba(99, 102, 241, 0.08);
		box-shadow: 0 0 18px rgba(99, 102, 241, 0.16);
		text-shadow: 0 0 12px rgba(129, 140, 248, 0.35);
	}

	.nav__link.is-active {
		color: #f5f3ff;
		background: rgba(76, 29, 149, 0.22);
		box-shadow:
			0 0 22px rgba(59, 130, 246, 0.28),
			0 0 34px rgba(168, 85, 247, 0.22),
			inset 0 0 18px rgba(99, 102, 241, 0.12);
		text-shadow:
			0 0 10px rgba(96, 165, 250, 0.75),
			0 0 22px rgba(168, 85, 247, 0.55);
	}

	.nav__link.is-active::after {
		transform: scaleX(1);
		opacity: 1;
	}

	.nav__actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		justify-self: end;
		flex-shrink: 0;
	}

	.nav__link:focus-visible,
	.nav__buy:focus-visible,
	.nav__toggle:focus-visible,
	.nav__brand:focus-visible {
		outline: 2px solid rgba(167, 139, 250, 0.85);
		outline-offset: 3px;
	}

	.nav__buy {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 4.75rem;
		height: 2.35rem;
		padding: 0 1.15rem;
		border-radius: 999px;
		border: 1px solid rgba(191, 219, 254, 0.35);
		background: linear-gradient(135deg, #2563eb 0%, #7c3aed 48%, #c026d3 100%);
		color: #ffffff;
		font-size: 0.86rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: lowercase;
		box-shadow:
			0 0 24px rgba(59, 130, 246, 0.45),
			0 0 36px rgba(124, 58, 237, 0.35),
			0 8px 20px rgba(76, 29, 149, 0.28);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease,
			filter 0.3s ease;
		animation: nav-buy-glow 2.8s ease-in-out infinite;
	}

	.nav__buy:hover {
		transform: translateY(-1px) scale(1.03);
		filter: brightness(1.06);
		box-shadow:
			0 0 30px rgba(59, 130, 246, 0.62),
			0 0 44px rgba(168, 85, 247, 0.48),
			0 10px 24px rgba(76, 29, 149, 0.34);
		color: #ffffff;
	}

	.nav__toggle {
		display: none;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		flex-shrink: 0;
		border: 1px solid rgba(129, 140, 248, 0.2);
		border-radius: 0.75rem;
		background: rgba(99, 102, 241, 0.12);
		color: var(--color-ink);
		cursor: pointer;
		transition:
			background 0.3s ease,
			border-color 0.3s ease;
	}

	.nav__toggle:hover {
		background: rgba(99, 102, 241, 0.2);
		border-color: rgba(167, 139, 250, 0.35);
	}

	.nav__toggle-icon,
	.nav__toggle-icon::before,
	.nav__toggle-icon::after {
		display: block;
		width: 16px;
		height: 2px;
		border-radius: 2px;
		background: currentColor;
		transition:
			transform 0.3s ease,
			opacity 0.3s ease;
	}

	.nav__toggle-icon {
		position: relative;
	}

	.nav__toggle-icon::before,
	.nav__toggle-icon::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.nav__toggle-icon::before {
		top: -5px;
	}

	.nav__toggle-icon::after {
		top: 5px;
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon {
		background: transparent;
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon::before {
		top: 0;
		transform: rotate(45deg);
	}

	.nav__toggle[aria-expanded='true'] .nav__toggle-icon::after {
		top: 0;
		transform: rotate(-45deg);
	}

	@keyframes nav-buy-glow {
		0%,
		100% {
			box-shadow:
				0 0 20px rgba(59, 130, 246, 0.38),
				0 0 30px rgba(124, 58, 237, 0.28),
				0 8px 20px rgba(76, 29, 149, 0.24);
		}
		50% {
			box-shadow:
				0 0 28px rgba(59, 130, 246, 0.58),
				0 0 42px rgba(168, 85, 247, 0.42),
				0 10px 24px rgba(76, 29, 149, 0.32);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav__buy {
			animation: none;
		}

		.nav__link,
		.nav__buy,
		.nav__toggle,
		.nav__bar,
		.nav__link::after {
			transition-duration: 0.01ms;
		}
	}

	@media (max-width: 980px) {
		.nav__bar {
			grid-template-columns: 1fr auto;
		}

		.nav__center,
		.nav__actions {
			display: none;
		}

		.nav__toggle {
			display: grid;
			justify-self: end;
		}

		.nav.is-open .nav__center,
		.nav.is-open .nav__actions {
			display: flex;
		}

		.nav.is-open .nav__bar {
			grid-template-columns: 1fr auto;
			grid-template-rows: auto auto auto;
			gap: 0.75rem;
			padding-bottom: 0.9rem;
		}

		.nav.is-open .nav__brand {
			grid-column: 1;
		}

		.nav.is-open .nav__toggle {
			grid-column: 2;
			grid-row: 1;
		}

		.nav.is-open .nav__center {
			grid-column: 1 / -1;
			grid-row: 2;
			display: flex;
			width: 100%;
		}

		.nav.is-open .nav__actions {
			grid-column: 1 / -1;
			grid-row: 3;
			display: flex;
			width: 100%;
		}

		.nav.is-open .nav__list {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			gap: 0.35rem;
		}

		.nav.is-open .nav__link {
			justify-content: flex-start;
			width: 100%;
			padding: 0.85rem 1rem;
			font-size: 0.98rem;
		}

		.nav.is-open .nav__buy {
			width: 100%;
			min-height: 2.85rem;
			font-size: 0.95rem;
		}
	}

	@media (max-width: 420px) {
		.nav__name {
			display: none;
		}
	}
</style>
