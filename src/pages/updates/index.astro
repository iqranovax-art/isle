---
import PageLayout from '../../layouts/PageLayout.astro';
import { siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'Theisle cheats Updates - Changelog & Notices';
const description = siteConfig.metaDescription;
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/updates/"
	heading="The Isle Cheats Updates"
	intro="Product maintenance notes for The Isle Cheats. Check here after game patches or when a feature page references a new build."
	heroImage={theIsleImages.product[1].src}
	heroAlt="The Isle Cheats updates visual"
	gallery={[theIsleImages.hero, theIsleImages.product[1], theIsleImages.product[2]]}
	ctaPrimary={{ href: '/features/', label: 'View Features' }}
	ctaSecondary={{ href: '/support/', label: 'Contact Support' }}
>
	<section class="card-panel">
		<h2>Latest notice</h2>
		<h3>Site and package information refresh</h3>
		<p>
			The product pages for The Isle ESP, The Isle Aimbot, pricing, and support are organized into dedicated
			URLs so players can review information by intent. Future build-specific notes will be posted here as they
			are released.
		</p>
	</section>

	<section class="card-panel">
		<h2>How updates are handled</h2>
		<p>
			When The Isle receives a patch that affects package behavior, a short note will be added to this page.
			For feature explanations, use <a href="/features/">Features</a>. For purchase decisions, use
			<a href="/pricing/">Pricing</a>.
		</p>
	</section>
</PageLayout>
