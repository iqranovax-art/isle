---
import PageLayout from '../../layouts/PageLayout.astro';
import { cloudDmaOption, productInfo, getPageDescription } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'Cheats - Instant Rotation & More | The Isle Cheats';
const description = getPageDescription('/cheats/');
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/cheats/"
	heading="Cheats"
	intro="Hacks inside The Isle Cheats, including Instant Rotation, Auto-Attack, Omnimovement, and other combat and movement options. Included in the Cloud-DMA package."
	heroImage={theIsleImages.product[0].src}
	heroAlt="The Isle Cheats preview"
	gallery={[theIsleImages.product[0], theIsleImages.product[1], theIsleImages.product[4]]}
	ctaPrimary={{ href: '/pricing/', label: 'Choose a Package' }}
	ctaSecondary={{ href: '/theisle-esp/', label: 'Explore ESP' }}
>
	<section class="card-panel">
		<h2>Cheat features</h2>
		<ul>
			{productInfo.features.cheats.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2>Cloud-DMA option</h2>
		<p>
			{cloudDmaOption.summary} See the <a href="/features/">Features</a> page for the full Cloud-DMA
			breakdown.
		</p>
	</section>

	<section class="card-panel">
		<h2>Related pages</h2>
		<ul>
			<li><a href="/theisle-esp/">Visuals ESP and World ESP</a></li>
			<li><a href="/features/">Complete feature list</a></li>
			<li><a href="/pricing/">Pricing and package lengths</a></li>
			<li><a href="/faq/">FAQ</a></li>
		</ul>
	</section>
</PageLayout>
