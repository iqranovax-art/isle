---
import { theIsleImages } from '../data/theisle';
import { siteConfig } from '../data/site';
import SeoImage from './SeoImage.astro';

interface Props {
	detailed?: boolean;
}

const { detailed = false } = Astro.props;

const featured =
	theIsleImages.gallery.find((image) => 'featured' in image && image.featured) ??
	theIsleImages.gallery[0];
const tiles = detailed ? theIsleImages.gallery.filter((image) => image.src !== featured.src) : theIsleImages.gallery.filter((image) => image.src !== featured.src).slice(0, 4);

const cheatHighlights = [
	{
		title: 'Visuals ESP (WH)',
		copy: 'Track entities with boxes, snaplines, health, growth, stamina, and custom colors up to 2000 m.',
	},
	{
		title: 'World ESP',
		copy: 'See bodies, meat, fruits, herbs, mushrooms, and water sources across the map.',
	},
	{
		title: 'Cheats',
		copy: 'Instant Rotation, Auto-Attack, Omnimovement, and other movement and combat options.',
	},
] as const;
---

<section class="gallery" id="gallery" aria-labelledby="gallery-title">
	<header class="gallery__head">
		<p class="gallery__eyebrow">{siteConfig.name}</p>
		<h2 id="gallery-title" class="gallery__title">Game Context Gallery</h2>
		<p class="gallery__sub">
			{
				detailed
					? 'Full visual index for The Isle Cheats ESP, World ESP, and Cheats — each image includes descriptive captions and search keywords for Google image indexing.'
					: 'Short visual previews paired with feature context so the section explains the cheat set instead of only showing oversized screenshots.'
			}
		</p>
	</header>

	<div class="gallery__layout">
		<div class="gallery__content">
			{
				!detailed && (
					<div class="gallery__summary">
						<p class="gallery__lead">
							{siteConfig.name} combines Cloud-DMA ESP, World ESP, and Cheats into one configurable package.
						</p>

						<div class="gallery__highlights">
							{
								cheatHighlights.map((item) => (
									<article class="gallery__info-card">
										<h3>{item.title}</h3>
										<p>{item.copy}</p>
									</article>
								))
							}
						</div>
					</div>
				)
			}

			<div class="gallery__media">
				<div class:list={['gallery__featured', 'media-frame', { 'gallery__featured--detailed': detailed }]}>
					<SeoImage
						src={featured.src}
						alt={featured.alt}
						width={1400}
						height={788}
						loading="lazy"
						showCaption={detailed}
						captionClass="gallery__caption"
					/>
				</div>

				<div class:list={['gallery__grid', { 'gallery__grid--detailed': detailed }]}>
					{
						tiles.map((image) => (
							<div class="gallery__item media-frame">
								<SeoImage
									src={image.src}
									alt={image.alt}
									width={1280}
									height={720}
									loading="lazy"
									showCaption={detailed}
									captionClass="gallery__caption"
								/>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.gallery {
		width: 100%;
	}

	.gallery__head {
		margin-bottom: 1.25rem;
	}

	.gallery__eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-orchid);
	}

	.gallery__title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 3vw, 2.2rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.gallery__sub {
		margin: 0.55rem 0 0;
		color: var(--color-muted);
		max-width: 36rem;
		line-height: 1.55;
	}

	.gallery__layout {
		border: 1px solid rgba(168, 85, 247, 0.12);
		border-radius: 1.1rem;
		background: rgba(18, 16, 26, 0.46);
		overflow: hidden;
	}

	.gallery__content {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
		align-items: stretch;
		gap: 1rem;
		padding: 1rem;
	}

	.gallery__content:has(.gallery__grid--detailed) {
		grid-template-columns: 1fr;
	}

	.gallery__summary {
		display: grid;
		gap: 1rem;
		align-content: start;
	}

	.gallery__lead {
		margin: 0;
		padding: 1rem 1.05rem;
		border-radius: 0.95rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(26, 22, 38, 0.72);
		color: #e2d9ef;
		line-height: 1.7;
	}

	.gallery__highlights {
		display: grid;
		gap: 0.75rem;
	}

	.gallery__info-card {
		padding: 0.95rem 1rem;
		border-radius: 0.9rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(10, 6, 18, 0.34);
	}

	.gallery__info-card h3 {
		margin: 0;
		font-size: 0.98rem;
		font-weight: 750;
		color: var(--color-ink);
	}

	.gallery__info-card p {
		margin: 0.45rem 0 0;
		color: var(--color-muted);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.gallery__media {
		display: grid;
		gap: 0.85rem;
	}

	.gallery__featured,
	.gallery__item {
		overflow: hidden;
	}

	.gallery__featured {
		aspect-ratio: 16 / 9;
		border: 1px solid rgba(192, 132, 252, 0.2);
	}

	.gallery__featured--detailed {
		aspect-ratio: auto;
	}

	.gallery__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.gallery__grid--detailed {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.gallery__item {
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.gallery__grid--detailed .gallery__item {
		aspect-ratio: auto;
	}

	.gallery__featured :global(.seo-image img),
	.gallery__item :global(.seo-image img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.gallery__featured--detailed :global(.seo-image img),
	.gallery__grid--detailed .gallery__item :global(.seo-image img) {
		aspect-ratio: 16 / 9;
		height: auto;
	}

	.gallery :global(.gallery__caption) {
		padding: 0.7rem 0.85rem 0.8rem;
		background: rgba(10, 6, 18, 0.94);
	}

	@media (max-width: 900px) {
		.gallery__content {
			grid-template-columns: 1fr;
		}

		.gallery__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.gallery__grid--detailed {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.gallery__content {
			padding: 0.8rem;
		}

		.gallery__grid,
		.gallery__grid--detailed {
			grid-template-columns: 1fr;
			gap: 0.65rem;
		}

		.gallery__featured {
			aspect-ratio: 4 / 3;
		}
	}
</style>
