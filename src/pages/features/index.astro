---
import PageLayout from '../../layouts/PageLayout.astro';
import { productInfo, siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'Theisle cheats Features - ESP, Aimbot & More';
const description = siteConfig.metaDescription;
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/features/"
	heading="The Isle Cheats Features"
	intro="Compare ESP, Aimbot, and general package options in one place before choosing a duration on Pricing."
	heroImage={theIsleImages.hero}
	heroAlt="The Isle Cheats features overview visual"
	gallery={theIsleImages.gallery.slice(1, 4)}
	ctaPrimary={{ href: '/pricing/', label: 'Compare Pricing' }}
	ctaSecondary={{ href: '/faq/', label: 'Read FAQ' }}
>
	<section class="card-panel">
		<h2>ESP features</h2>
		<ul>
			{productInfo.features.esp.map((item) => <li>{item}</li>)}
		</ul>
		<div class="cta-row">
			<a class="cta-btn cta-btn--ghost" href="/theisle-esp/">ESP details</a>
		</div>
	</section>

	<section class="card-panel">
		<h2>Aimbot features</h2>
		<ul>
			{productInfo.features.aimbot.map((item) => <li>{item}</li>)}
		</ul>
		<div class="cta-row">
			<a class="cta-btn cta-btn--ghost" href="/theisle-aimbot/">Aimbot details</a>
		</div>
	</section>

	<section class="card-panel">
		<h2>General package features</h2>
		<ul>
			{productInfo.features.general.map((item) => <li>{item}</li>)}
		</ul>
	</section>
</PageLayout>
