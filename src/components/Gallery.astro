---
import { theIsleImages } from '../data/theisle';
import { siteConfig } from '../data/site';

const featured =
	theIsleImages.gallery.find((image) => 'featured' in image && image.featured) ??
	theIsleImages.gallery[0];
const tiles = theIsleImages.gallery.filter((image) => image.src !== featured.src).slice(0, 4);

const cheatHighlights = [
	{
		title: 'Player & Dino ESP',
		copy: 'Track nearby players and dinosaurs with readable overlays, distance cues, and faster threat checks during encounters.',
	},
	{
		title: 'Species Visibility',
		copy: 'Review carnivore and herbivore awareness tools that help you read the map without overloading the screen.',
	},
	{
		title: 'Aimbot Controls',
		copy: 'Compare smoothness, targeting, and toggle behavior so the feature set stays easy to understand before purchase.',
	},
] as const;
---

<section class="gallery" id="gallery" aria-labelledby="gallery-title">
	<header class="gallery__head">
		<p class="gallery__eyebrow">{siteConfig.name}</p>
		<h2 id="gallery-title" class="gallery__title">Game Context Gallery</h2>
		<p class="gallery__sub">
			Short visual previews paired with feature context so the section explains the cheat set instead of only
			showing oversized screenshots.
		</p>
	</header>

	<div class="gallery__layout">
		<div class="gallery__content">
			<div class="gallery__summary">
				<p class="gallery__lead">
					{siteConfig.name} combines survival awareness and combat support into a tighter overlay package built
					around readable visuals.
				</p>

				<div class="gallery__highlights">
					{
						cheatHighlights.map((item) => (
							<article class="gallery__info-card">
								<h3>{item.title}</h3>
								<p>{item.copy}</p>
							</article>
						))
					}
				</div>
			</div>

			<div class="gallery__media">
				<figure class="gallery__featured media-frame">
					<img
						src={featured.src}
						alt={featured.alt}
						width="1400"
						height="788"
						loading="lazy"
						decoding="async"
					/>
					<figcaption>{featured.alt}</figcaption>
				</figure>

				<div class="gallery__grid">
					{
						tiles.map((image) => (
							<figure class="gallery__item media-frame">
								<img src={image.src} alt={image.alt} width="1280" height="720" loading="lazy" decoding="async" />
								<figcaption>{image.alt}</figcaption>
							</figure>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.gallery {
		width: 100%;
		content-visibility: auto;
		contain-intrinsic-size: 1px 900px;
	}

	.gallery__head {
		margin-bottom: 1.25rem;
	}

	.gallery__eyebrow {
		margin: 0 0 0.4rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-orchid);
	}

	.gallery__title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 3vw, 2.2rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.gallery__sub {
		margin: 0.55rem 0 0;
		color: var(--color-muted);
		max-width: 36rem;
		line-height: 1.55;
	}

	.gallery__layout {
		border: 1px solid rgba(168, 85, 247, 0.12);
		border-radius: 1.1rem;
		background: rgba(18, 16, 26, 0.46);
		overflow: hidden;
	}

	.gallery__content {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.35fr);
		align-items: start;
		gap: 1rem;
		padding: 1rem;
	}

	.gallery__summary {
		display: grid;
		gap: 1rem;
		align-content: start;
	}

	.gallery__lead {
		margin: 0;
		padding: 1rem 1.05rem;
		border-radius: 0.95rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(26, 22, 38, 0.72);
		color: #e2d9ef;
		line-height: 1.7;
	}

	.gallery__highlights {
		display: grid;
		gap: 0.75rem;
	}

	.gallery__info-card {
		padding: 0.95rem 1rem;
		border-radius: 0.9rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(10, 6, 18, 0.34);
	}

	.gallery__info-card h3 {
		margin: 0;
		font-size: 0.98rem;
		font-weight: 750;
		color: var(--color-ink);
	}

	.gallery__info-card p {
		margin: 0.45rem 0 0;
		color: var(--color-muted);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.gallery__media {
		display: grid;
		gap: 0.85rem;
	}

	.gallery__featured,
	.gallery__item {
		margin: 0;
	}

	.gallery__featured {
		aspect-ratio: 16 / 9;
		border: 1px solid rgba(192, 132, 252, 0.22);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.26);
	}

	.gallery__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.gallery__item {
		aspect-ratio: 16 / 11;
	}

	.gallery__featured img,
	.gallery__item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.45s ease;
	}

	.gallery__featured:hover img,
	.gallery__item:hover img {
		transform: scale(1.03);
	}

	.gallery__featured figcaption,
	.gallery__item figcaption {
		position: absolute;
		inset: auto 0 0;
		z-index: 2;
		padding: 1.6rem 0.95rem 0.8rem;
		background: linear-gradient(transparent, rgba(10, 6, 18, 0.92));
		color: #ddd4ec;
		font-size: 0.75rem;
		font-weight: 600;
		opacity: 0;
		transform: translateY(6px);
		transition:
			opacity 0.25s ease,
			transform 0.25s ease;
	}

	.gallery__featured:hover figcaption,
	.gallery__item:hover figcaption {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 900px) {
		.gallery__content {
			grid-template-columns: 1fr;
		}

		.gallery__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.gallery__content {
			padding: 0.8rem;
		}

		.gallery__grid {
			grid-template-columns: 1fr;
			gap: 0.65rem;
		}

		.gallery__featured {
			aspect-ratio: 4 / 3;
		}
	}
</style>
