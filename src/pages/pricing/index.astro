---
import PageLayout from '../../layouts/PageLayout.astro';
import { productInfo, siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'The Isle Cheats Pricing - Monthly & Lifetime';
const description = siteConfig.metaDescription;
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/pricing/"
	heading="The Isle Cheats Pricing"
	intro="Packages are sold in USD and include the The Isle Cheats Cloud-DMA, ESP, and Exploits product line."
	heroImage={theIsleImages.cover}
	heroAlt="The Isle Cheats pricing visual"
	gallery={[theIsleImages.product[1], theIsleImages.product[3], theIsleImages.product[5]]}
	ctaPrimary={{ href: '/#product', label: 'Open Product Card' }}
	ctaSecondary={{ href: '/features/', label: 'See Features' }}
>
	<section class="card-panel">
		<h2>Current packages</h2>
		<div class="price-grid">
			{
				productInfo.plans.map((plan) => (
					<article class:list={['price-card', { 'is-featured': plan.id === 'lifetime' }]}>
						<span class="price-card__label">{plan.label}</span>
						<span class="price-card__price">${plan.price}</span>
						<span class="price-card__meta">{productInfo.currency} · Cloud-DMA · ESP</span>
					</article>
				))
			}
		</div>
	</section>

	<section class="card-panel">
		<h2>What each package includes</h2>
		<p>
			Each package includes access to the The Isle Cheats feature set described on
			<a href="/features/">Features</a>, including Cloud-DMA, Visuals ESP, World ESP, and Exploits. Delivery method:
			{productInfo.delivery}.
		</p>
	</section>

	<section class="card-panel">
		<h2>Before you buy</h2>
		<ul>
			<li><a href="/refund-policy/">Read the refund policy</a></li>
			<li><a href="/terms/">Review the terms</a></li>
			<li><a href="/updates/">Check the latest updates</a></li>
			<li>
				<a href={`mailto:${siteConfig.supportEmail}`}>Email support</a> if you need order help
			</li>
		</ul>
	</section>
</PageLayout>
