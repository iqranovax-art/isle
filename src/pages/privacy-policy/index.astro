---
import PageLayout from '../../layouts/PageLayout.astro';
import { siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'Privacy Policy - Theisle cheats';
const description = siteConfig.metaDescription;
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/privacy-policy/"
	heading="Privacy Policy"
	intro="How information is handled when you browse islecheats.net or contact support."
	eyebrow="Legal"
	heroImage={theIsleImages.product[0].src}
	heroAlt="The Isle Cheats privacy policy visual"
	gallery={[theIsleImages.product[0], theIsleImages.product[2], theIsleImages.hero]}
	ctaPrimary={{ href: `mailto:${siteConfig.supportEmail}`, label: 'Email Us' }}
	ctaSecondary={{ href: '/terms/', label: 'Terms of Use' }}
>
	<section class="card-panel">
		<h2>Information we may collect</h2>
		<ul>
			<li>Contact details you send by email</li>
			<li>Order references needed to resolve support requests</li>
			<li>Basic technical data used to operate and secure the website</li>
		</ul>
	</section>

	<section class="card-panel">
		<h2>How information is used</h2>
		<p>
			Information is used to respond to support requests, process order issues, improve site reliability, and
			meet legal obligations when required.
		</p>
	</section>

	<section class="card-panel">
		<h2>Contact</h2>
		<p>
			Privacy questions can be sent to
			<a href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>.
		</p>
	</section>
</PageLayout>
