---
import { theIsleImages } from '../data/theisle';
import { productInfo, siteConfig } from '../data/site';

interface Plan {
	id: string;
	label: string;
	price: number;
	stock: string;
}

interface Props {
	name?: string;
	plans?: Plan[];
	defaultPlan?: string;
}

const {
	name = productInfo.name,
	plans = productInfo.plans.map((plan) => ({ ...plan, stock: 'Available' })),
	defaultPlan = 'monthly',
} = Astro.props;

const images = theIsleImages.product;
const main = images[0];
const active = plans.find((plan) => plan.id === defaultPlan) ?? plans[0];
---

<section class="product surface-card" id="product" data-product aria-label="Product details">
	<div class="product__media">
		<figure class="product__figure media-frame">
			<img
				src={main.src}
				alt={main.alt}
				width="1280"
				height="720"
				class="product__image"
				data-main-image
				decoding="async"
			/>
			<span class="product__credit">Preview</span>
		</figure>
		<div class="product__thumbs" role="list">
			{
				images.map((image, index) => (
					<button
						type="button"
						class:list={['product__thumb media-frame', { 'is-active': index === 0 }]}
						aria-label={`Show ${image.alt}`}
						aria-pressed={index === 0 ? 'true' : 'false'}
						data-thumb
						data-src={image.src}
						data-alt={image.alt}
					>
						<img src={image.src} alt={image.alt} width="320" height="200" loading="lazy" decoding="async" />
					</button>
				))
			}
		</div>
	</div>

	<div class="product__details">
		<h2 class="product__title">{name}</h2>

		<div class="product__badges">
			<span class="badge">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path
						d="M12 3l2.2 4.5 5 .7-3.6 3.5.9 5.1L12 14.8 7.5 16.8l.9-5.1L4.8 8.2l5-.7L12 3z"
						stroke="currentColor"
						stroke-width="1.6"
						stroke-linejoin="round"></path>
				</svg>
				{productInfo.game}
			</span>
			<span class="badge">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<circle cx="12" cy="12" r="8.25" stroke="currentColor" stroke-width="1.6"></circle>
					<path d="M12 8v4.2l2.5 1.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
					></path>
				</svg>
				Digital Delivery
			</span>
			<span class="badge badge--status">
				<span class="badge__dot" aria-hidden="true"></span>
				Cloud-DMA · ESP
			</span>
		</div>

		<div class="product__price-row">
			<p class="product__price">
				$<span data-price>{active.price}</span>
			</p>
			<div class="qty" data-qty>
				<button type="button" class="qty__btn" data-qty-minus aria-label="Decrease quantity">−</button>
				<span class="qty__value" data-qty-value aria-live="polite">1</span>
				<button type="button" class="qty__btn" data-qty-plus aria-label="Increase quantity">+</button>
			</div>
		</div>

		<div class="plans" role="radiogroup" aria-label="Subscription length">
			{
				plans.map((plan) => (
					<button
						type="button"
						class:list={['plan', { 'is-active': plan.id === active.id }]}
						role="radio"
						aria-checked={plan.id === active.id}
						data-plan={plan.id}
						data-plan-price={plan.price}
					>
						<span class="plan__label">{plan.label}</span>
						<span class="plan__price">${plan.price}</span>
						<span class="plan__stock">{plan.stock}</span>
					</button>
				))
			}
		</div>

		<a href={siteConfig.checkoutUrl} class="cart-btn bg-brand">
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<path
					d="M3.5 5h1.7l1.4 10.2a1.5 1.5 0 001.5 1.3h8.7a1.5 1.5 0 001.5-1.2L20 8H7"
					stroke="currentColor"
					stroke-width="1.7"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
				<circle cx="9.5" cy="19.5" r="1.3" fill="currentColor"></circle>
				<circle cx="17" cy="19.5" r="1.3" fill="currentColor"></circle>
			</svg>
			Add To Cart
		</a>

		<div class="buy-also">
			<p class="buy-also__label">More options</p>
			<div class="buy-also__row">
				<a href="/features/" class="alt-link">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M10 6H7a3 3 0 00-3 3v8a3 3 0 003 3h8a3 3 0 003-3v-3"
							stroke="currentColor"
							stroke-width="1.6"
							stroke-linecap="round"></path>
						<path
							d="M14 4h6v6M20 4l-9 9"
							stroke="currentColor"
							stroke-width="1.6"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
					Full feature breakdown
				</a>
				<a href="/pricing/" class="alt-link">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M4 8.5h16v7a2 2 0 01-2 2H6a2 2 0 01-2-2v-7z"
							stroke="currentColor"
							stroke-width="1.6"></path>
						<path d="M4 10.5c3 2.2 5 3.3 8 3.3s5-1.1 8-3.3" stroke="currentColor" stroke-width="1.6"
						></path>
					</svg>
					Monthly vs lifetime plans
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	const root = document.querySelector('[data-product]');
	if (root) {
		const priceEl = root.querySelector('[data-price]');
		const qtyValue = root.querySelector('[data-qty-value]');
		const mainImage = root.querySelector('[data-main-image]') as HTMLImageElement | null;
		const planButtons = root.querySelectorAll('[data-plan]');
		const thumbs = root.querySelectorAll('[data-thumb]');
		let qty = 1;

		thumbs.forEach((thumb) => {
			thumb.addEventListener('click', () => {
				const src = thumb.getAttribute('data-src');
				const alt = thumb.getAttribute('data-alt');
				if (mainImage && src) {
					mainImage.style.opacity = '0';
					window.setTimeout(() => {
						mainImage.src = src;
						if (alt) mainImage.alt = alt;
						mainImage.style.opacity = '1';
					}, 140);
				}
				thumbs.forEach((other) => {
					other.classList.remove('is-active');
					other.setAttribute('aria-pressed', 'false');
				});
				thumb.classList.add('is-active');
				thumb.setAttribute('aria-pressed', 'true');
			});
		});

		root.querySelector('[data-qty-minus]')?.addEventListener('click', () => {
			qty = Math.max(1, qty - 1);
			if (qtyValue) qtyValue.textContent = String(qty);
		});

		root.querySelector('[data-qty-plus]')?.addEventListener('click', () => {
			qty = Math.min(99, qty + 1);
			if (qtyValue) qtyValue.textContent = String(qty);
		});

		planButtons.forEach((btn) => {
			btn.addEventListener('click', () => {
				planButtons.forEach((other) => {
					other.classList.remove('is-active');
					other.setAttribute('aria-checked', 'false');
				});
				btn.classList.add('is-active');
				btn.setAttribute('aria-checked', 'true');
				const next = btn.getAttribute('data-plan-price');
				if (priceEl && next) priceEl.textContent = next;
			});
		});
	}
</script>

<style>
	.product {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(0, 1fr);
		gap: clamp(1.5rem, 3vw, 2.5rem);
		align-items: start;
		width: 100%;
		margin: 0;
		padding: clamp(1.25rem, 2.5vw, 2rem);
		border-radius: var(--radius-card);
		animation: card-in 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
	}

	.product__media {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-width: 0;
	}

	.product__figure {
		margin: 0;
		aspect-ratio: 16 / 10;
		border: 1px solid rgba(192, 132, 252, 0.28);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
	}

	.product__image {
		transition:
			transform 0.45s ease,
			opacity 0.14s ease;
	}

	.product__figure:hover .product__image {
		transform: scale(1.025);
	}

	.product__credit {
		position: absolute;
		right: 0.7rem;
		bottom: 0.7rem;
		z-index: 2;
		padding: 0.28rem 0.55rem;
		border-radius: 999px;
		background: rgba(10, 6, 18, 0.72);
		border: 1px solid rgba(192, 132, 252, 0.25);
		color: #d8c9ef;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		backdrop-filter: blur(6px);
	}

	.product__thumbs {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.55rem;
	}

	.product__thumb {
		padding: 0;
		aspect-ratio: 16 / 10;
		width: 100%;
		border: 2px solid transparent;
		border-radius: 0.75rem;
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.product__thumb.is-active,
	.product__thumb:hover {
		border-color: var(--color-orchid);
		transform: translateY(-1px);
	}

	.product__title {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.85rem, 3.5vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.product__badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1rem;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.75rem;
		border-radius: 999px;
		border: 1px solid rgba(192, 132, 252, 0.25);
		background: rgba(34, 28, 48, 0.9);
		color: var(--color-orchid);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.badge--status {
		color: var(--color-mint);
		border-color: rgba(52, 211, 153, 0.3);
	}

	.badge__dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--color-mint);
	}

	.product__price-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 1.35rem;
	}

	.product__price {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.qty {
		display: inline-flex;
		align-items: center;
		border-radius: 0.7rem;
		border: 1px solid rgba(192, 132, 252, 0.22);
		background: rgba(18, 16, 26, 0.9);
		overflow: hidden;
	}

	.qty__btn {
		width: 2.4rem;
		height: 2.4rem;
		border: 0;
		background: transparent;
		color: var(--color-ink);
		font-size: 1.15rem;
		line-height: 1;
		transition: background 0.15s ease;
	}

	.qty__btn:hover {
		background: rgba(168, 85, 247, 0.18);
	}

	.qty__value {
		min-width: 2rem;
		text-align: center;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.plans {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		margin-top: 1.35rem;
	}

	.plan {
		display: grid;
		gap: 0.25rem;
		padding: 0.95rem 0.75rem;
		border-radius: 0.85rem;
		border: 1px solid rgba(192, 132, 252, 0.18);
		background: rgba(26, 22, 38, 0.95);
		color: var(--color-ink);
		text-align: left;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background 0.2s ease;
	}

	.plan:hover {
		border-color: rgba(192, 132, 252, 0.45);
		transform: translateY(-2px);
	}

	.plan.is-active {
		border-color: transparent;
		background: var(--gradient-brand);
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28);
	}

	.plan__label {
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.plan__price {
		font-size: 0.95rem;
		font-weight: 600;
		opacity: 0.95;
	}

	.plan__stock {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	.plan.is-active .plan__stock {
		color: #bbf7d0;
	}

	.cart-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		width: 100%;
		margin-top: 1.25rem;
		padding: 1rem 1.25rem;
		border: 0;
		border-radius: 0.9rem;
		color: white;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.01em;
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.28);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			filter 0.2s ease;
	}

	.cart-btn:hover {
		transform: translateY(-1px);
		filter: brightness(1.05);
		box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
		color: white;
	}

	.buy-also {
		margin-top: 1.35rem;
	}

	.buy-also__label {
		margin: 0 0 0.65rem;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-faint);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.buy-also__row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
	}

	.alt-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.65rem 0.95rem;
		border-radius: 999px;
		border: 1px solid rgba(192, 132, 252, 0.2);
		background: rgba(26, 22, 38, 0.8);
		color: var(--color-muted);
		font-size: 0.82rem;
		font-weight: 600;
		transition:
			color 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.alt-link:hover {
		color: var(--color-ink);
		border-color: rgba(192, 132, 252, 0.45);
		background: rgba(48, 36, 72, 0.85);
	}

	@keyframes card-in {
		from {
			opacity: 0;
			transform: translateY(22px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.product__details {
		min-width: 0;
		padding-top: 0.15rem;
	}

	@media (max-width: 900px) {
		.product {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		.plans {
			grid-template-columns: 1fr;
		}

		.alt-link {
			flex: 1 1 100%;
			justify-content: center;
			min-height: 2.75rem;
		}

		.cart-btn {
			min-height: 3.1rem;
		}

		.product__price-row {
			align-items: center;
		}

		.qty__btn {
			min-width: 2.75rem;
			min-height: 2.75rem;
		}
	}
</style>
