---
import PageLayout from '../../layouts/PageLayout.astro';
import { cloudDmaOption, productInfo, getPageDescription, siteConfig } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'The Isle Cheats Features - Cloud-DMA, ESP & Cheats';
const description = getPageDescription('/features/');
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/features/"
	heading="The Isle Cheats Features"
	intro="Compare Cloud-DMA, Visuals ESP, World ESP, Cheats, and Other hacks in one place before choosing a duration on Pricing."
	heroImage={theIsleImages.hero}
	heroAlt="The Isle Cheats features overview visual"
	gallery={theIsleImages.gallery.slice(1, 4)}
	ctaPrimary={{ href: siteConfig.checkoutUrl, label: 'Compare Pricing' }}
	ctaSecondary={{ href: siteConfig.checkoutUrl, label: 'Get Access' }}
>
	<section class="card-panel">
		<h2>{cloudDmaOption.label} option</h2>
		<p>{cloudDmaOption.summary}</p>
		<ul>
			<li>Visuals ESP (WH)</li>
			<li>World ESP (Environment)</li>
			<li>Cheats (Instant Rotation, Auto-Attack, and more)</li>
			<li>Other (The Isle) utilities</li>
			<li>Not included: {cloudDmaOption.excludes.join(', ')}</li>
		</ul>
	</section>

	<section class="card-panel">
		<h2>Visuals ESP (WH)</h2>
		<ul>
			{productInfo.features.visualsEsp.map((item) => <li>{item}</li>)}
		</ul>
		<div class="cta-row">
			<a class="cta-btn cta-btn--ghost" href="/theisle-esp/">ESP details</a>
		</div>
	</section>

	<section class="card-panel">
		<h2>World ESP (Environment)</h2>
		<ul>
			{productInfo.features.worldEsp.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2 id="cheats">Cheats</h2>
		<ul>
			{productInfo.features.cheats.map((item) => <li>{item}</li>)}
		</ul>
		<div class="cta-row">
			<a class="cta-btn cta-btn--ghost" href="/cheats/">Cheats details</a>
		</div>
	</section>

	<section class="card-panel" id="other">
		<h2>Other (The Isle)</h2>
		<ul>
			{productInfo.features.other.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel" id="aimbot">
		<h2>Aimbot (not in Cloud-DMA)</h2>
		<p>Aimbot is available outside the Cloud-DMA option. Cloud-DMA buyers receive ESP, Cheats, and Other hacks only.</p>
		<ul>
			{productInfo.features.aimbot.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2>General package features</h2>
		<ul>
			{productInfo.features.general.map((item) => <li>{item}</li>)}
		</ul>
	</section>
</PageLayout>
