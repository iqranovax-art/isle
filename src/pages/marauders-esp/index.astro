---
import PageLayout from '../../layouts/PageLayout.astro';
import { productInfo } from '../../data/site';
import { maraudersImages } from '../../data/marauders';

const title = 'Marauders ESP – Player & Loot Visibility';
const description =
	'Explore Marauders ESP features for player visibility, loot markers, and distance readouts. See how ESP fits into Marauders Cheats packages.';
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/marauders-esp/"
	heading="Marauders ESP"
	intro="Marauders ESP focuses on on-screen information: players, loot markers, and distance cues that help you read a fight before you commit."
	heroImage={maraudersImages.product[2].src}
	heroAlt="Marauders ESP visibility preview"
	gallery={maraudersImages.product.slice(0, 3)}
	ctaPrimary={{ href: '/pricing/', label: 'View Pricing' }}
	ctaSecondary={{ href: '/marauders-aimbot/', label: 'See Aimbot' }}
>
	<section class="card-panel">
		<h2>ESP feature areas</h2>
		<ul>
			{productInfo.features.esp.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2>Player ESP and loot ESP</h2>
		<p>
			Player ESP helps you track nearby combatants. Loot ESP highlights nearby item opportunities. Both can
			be toggled in the interface so you keep only the information you need for the current raid.
		</p>
	</section>

	<section class="card-panel">
		<h2>Related pages</h2>
		<ul>
			<li><a href="/marauders-aimbot/">Marauders Aimbot controls</a></li>
			<li><a href="/features/">All Marauders Cheats features</a></li>
			<li><a href="/pricing/">Pricing and package lengths</a></li>
			<li><a href="/faq/">ESP and delivery FAQ</a></li>
		</ul>
	</section>
</PageLayout>
