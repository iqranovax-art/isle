---
import PageLayout from '../../layouts/PageLayout.astro';
import Gallery from '../../components/Gallery.astro';
import { siteConfig, getPageDescription } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'The Isle Cheats Demo Gallery';
const description = getPageDescription('/demo/');
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/demo/"
	heading="Game Context Gallery"
	intro="Visual previews for The Isle Cheats ESP, World ESP, and Cheats — each image paired with feature context."
	heroImage={theIsleImages.gallery[0].src}
	heroAlt={theIsleImages.gallery[0].alt}
	gallery={theIsleImages.gallery.slice(1, 5)}
	ctaPrimary={{ href: siteConfig.checkoutUrl, label: 'Get Access' }}
	ctaSecondary={{ href: '/features/', label: 'Explore Features' }}
>
	<section class="card-panel card-panel--flush">
		<Gallery />
	</section>
</PageLayout>

<style>
	.card-panel--flush {
		padding: 0;
		border: 0;
		background: transparent;
	}
</style>
