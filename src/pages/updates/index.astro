---
import PageLayout from '../../layouts/PageLayout.astro';
import { maraudersImages } from '../../data/marauders';

const title = 'Marauders Cheats Updates – Changelog & Notices';
const description =
	'Check Marauders Cheats updates, maintenance notices, and compatibility notes for ESP and Aimbot packages.';
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/updates/"
	heading="Marauders Cheats Updates"
	intro="Product maintenance notes for Marauders Cheats. Check here after game patches or when a feature page references a new build."
	heroImage={maraudersImages.product[1].src}
	heroAlt="Marauders Cheats updates visual"
	gallery={[maraudersImages.hero, maraudersImages.product[1], maraudersImages.product[2]]}
	ctaPrimary={{ href: '/features/', label: 'View Features' }}
	ctaSecondary={{ href: '/support/', label: 'Contact Support' }}
>
	<section class="card-panel">
		<h2>Latest notice</h2>
		<h3>Site and package information refresh</h3>
		<p>
			The product pages for Marauders ESP, Marauders Aimbot, pricing, and support are organized into dedicated
			URLs so players can review information by intent. Future build-specific notes will be posted here as they
			are released.
		</p>
	</section>

	<section class="card-panel">
		<h2>How updates are handled</h2>
		<p>
			When Marauders receives a patch that affects package behavior, a short note will be added to this page.
			For feature explanations, use <a href="/features/">Features</a>. For purchase decisions, use
			<a href="/pricing/">Pricing</a>.
		</p>
	</section>
</PageLayout>
