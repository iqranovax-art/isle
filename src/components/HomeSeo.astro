---
import { homeFaqs, productInfo } from '../data/site';
---

<section class="home-seo shell" aria-labelledby="home-seo-title">
	<div class="home-seo__panel card-surface">
		<h2 id="home-seo-title">Marauders Cheats for ESP and Aimbot</h2>
		<p>
			{productInfo.summary} Use this site to review feature details, compare packages on
			<a href="/pricing/">Pricing</a>, and check maintenance notes on
			<a href="/updates/">Updates</a>.
		</p>

		<div class="home-seo__grid">
			<article>
				<h3><a href="/marauders-esp/">Marauders ESP</a></h3>
				<p>Improve on-screen player and loot visibility with configurable ESP overlays.</p>
			</article>
			<article>
				<h3><a href="/marauders-aimbot/">Marauders Aimbot</a></h3>
				<p>Review aim assist options, smoothness controls, and hotkey toggles.</p>
			</article>
			<article>
				<h3><a href="/features/">Full feature list</a></h3>
				<p>See ESP, Aimbot, and general package options in one place.</p>
			</article>
			<article>
				<h3><a href="/support/">Support</a></h3>
				<p>Get help with delivery questions, setup, and order issues.</p>
			</article>
		</div>
	</div>

	<section class="home-seo__faq" aria-labelledby="home-faq-title">
		<h2 id="home-faq-title">Frequently asked questions</h2>
		<div class="home-seo__faq-list">
			{
				homeFaqs.map((item) => (
					<details class="home-seo__item">
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))
			}
		</div>
		<p class="home-seo__more">
			More answers are on the <a href="/faq/">FAQ page</a>. Policy details are in
			<a href="/refund-policy/">Refund Policy</a>,
			<a href="/privacy-policy/">Privacy Policy</a>, and
			<a href="/terms/">Terms</a>.
		</p>
	</section>
</section>

<style>
	.home-seo {
		display: grid;
		gap: 1.5rem;
		padding-bottom: 1rem;
	}

	.card-surface {
		padding: clamp(1.25rem, 3vw, 1.75rem);
		border-radius: var(--radius-card);
		border: 1px solid rgba(168, 85, 247, 0.16);
		background: rgba(26, 22, 38, 0.72);
	}

	.home-seo h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.35rem, 2.5vw, 1.75rem);
		font-weight: 800;
	}

	.home-seo p {
		margin: 0.85rem 0 0;
		color: var(--color-muted);
		line-height: 1.65;
	}

	.home-seo a {
		color: var(--color-orchid);
		font-weight: 600;
	}

	.home-seo a:hover {
		color: var(--color-ink);
	}

	.home-seo__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
		margin-top: 1.25rem;
	}

	.home-seo__grid article {
		padding: 1rem;
		border-radius: 0.9rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(10, 6, 18, 0.35);
	}

	.home-seo__grid h3 {
		margin: 0;
		font-size: 1rem;
		font-weight: 750;
	}

	.home-seo__grid p {
		margin-top: 0.45rem;
		font-size: 0.92rem;
	}

	.home-seo__faq-list {
		display: grid;
		gap: 0.65rem;
		margin-top: 1rem;
	}

	.home-seo__item {
		border-radius: 0.85rem;
		border: 1px solid rgba(168, 85, 247, 0.14);
		background: rgba(26, 22, 38, 0.65);
		padding: 0.85rem 1rem;
	}

	.home-seo__item summary {
		cursor: pointer;
		font-weight: 700;
		color: var(--color-ink);
	}

	.home-seo__item p {
		margin-top: 0.65rem;
	}

	.home-seo__more {
		font-size: 0.92rem;
	}

	@media (max-width: 720px) {
		.home-seo__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
