---
import PageLayout from '../../layouts/PageLayout.astro';
import { productInfo, getPageDescription } from '../../data/site';
import { theIsleImages } from '../../data/theisle';

const title = 'The Isle Cheats ESP - Visuals & World ESP';
const description = getPageDescription('/theisle-esp/');
---

<PageLayout
	title={title}
	description={description}
	canonicalPath="/theisle-esp/"
	heading="The Isle Cheats ESP"
	intro="Visuals ESP and World ESP for entity awareness, resource tracking, and environment readouts. Both are included in the Cloud-DMA option."
	heroImage={theIsleImages.product[2].src}
	heroAlt="The Isle ESP visibility preview"
	gallery={theIsleImages.product.slice(0, 3)}
	ctaPrimary={{ href: '/pricing/', label: 'View Pricing' }}
	ctaSecondary={{ href: '/theisle-exploits/', label: 'See Exploits' }}
>
	<section class="card-panel">
		<h2>Visuals ESP (WH)</h2>
		<ul>
			{productInfo.features.visualsEsp.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel" id="world-esp">
		<h2>World ESP (Environment)</h2>
		<ul>
			{productInfo.features.worldEsp.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="card-panel">
		<h2>Related pages</h2>
		<ul>
			<li><a href="/theisle-exploits/">The Isle Cheats Exploits</a></li>
			<li><a href="/features/">All The Isle Cheats features</a></li>
			<li><a href="/pricing/">Pricing and package lengths</a></li>
			<li><a href="/faq/">ESP and delivery FAQ</a></li>
		</ul>
	</section>
</PageLayout>
